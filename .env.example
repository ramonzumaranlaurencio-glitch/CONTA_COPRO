SUNAT_GUARD_BLOCK_ON_UNAVAILABLE=false
SUNAT_REALTIME_TIMEOUT_SECONDS=3
SUNAT_RUC=
SUNAT_SOL_USER=
SUNAT_SOL_PASSWORD=
SUNAT_XSD_DIR=./xsd
P12_CERT_PATH=./secrets/sunat_cert.p12
P12_CERT_PASSWORD=

