APP_NAME=CONTA_PRO Enterprise
APP_ENV=development
DATABASE_URL=postgresql+asyncpg://contapro:contapro@localhost:5432/contapro
REDIS_URL=redis://localhost:6379/0
LEDGER_HMAC_SECRET=change-this-secret-min-32-chars
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

GEMINI_API_KEY=
